-- ------------------------------------------------------------
-- 1. PROCEDURE (parameterized) - create a new repair job
--    Demonstrates: DML, exception handling, COMMIT/ROLLBACK
-- ------------------------------------------------------------
CREATE OR REPLACE PROCEDURE add_repair_job (
    p_item_id       IN repair_job.item_id%TYPE,
    p_technician_id IN repair_job.technician_id%TYPE,
    p_due_date      IN repair_job.date_due%TYPE
) AS
    v_exists NUMBER;
BEGIN
    -- validate the shoe item exists
    SELECT COUNT(*) INTO v_exists FROM shoe_item WHERE item_id = p_item_id;
    IF v_exists = 0 THEN
        RAISE_APPLICATION_ERROR(-20001, 'Shoe item ' || p_item_id || ' does not exist.');
    END IF;

    INSERT INTO repair_job (item_id, technician_id, date_due, status)
    VALUES (p_item_id, p_technician_id, p_due_date, 'RECEIVED');

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Repair job created for item ' || p_item_id);

EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Error creating job: ' || SQLERRM);
END add_repair_job;
/

