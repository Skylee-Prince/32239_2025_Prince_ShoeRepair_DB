-- ------------------------------------------------------------
-- 2. FUNCTION - total cost of a repair job
--    Demonstrates: RETURN value, aggregate query
-- ------------------------------------------------------------
CREATE OR REPLACE FUNCTION get_job_total (
    p_job_id IN repair_job.job_id%TYPE
) RETURN NUMBER AS
    v_total NUMBER := 0;
BEGIN
    SELECT NVL(SUM(js.quantity * st.base_price), 0)
    INTO v_total
    FROM job_service js
    JOIN service_type st ON st.service_id = js.service_id
    WHERE js.job_id = p_job_id;

    RETURN v_total;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RETURN 0;
END get_job_total;
/

