-- ------------------------------------------------------------
-- 3. PACKAGE - groups related job-status operations together
--    Demonstrates: package spec + body, procedure, function, cursor
-- ------------------------------------------------------------
CREATE OR REPLACE PACKAGE pkg_repair AS
    PROCEDURE update_job_status (p_job_id IN NUMBER, p_status IN VARCHAR2);
    FUNCTION  count_jobs_by_status (p_status IN VARCHAR2) RETURN NUMBER;
    PROCEDURE list_jobs_by_status (p_status IN VARCHAR2);
END pkg_repair;
/

CREATE OR REPLACE PACKAGE BODY pkg_repair AS

    -- update a job's status safely
    PROCEDURE update_job_status (p_job_id IN NUMBER, p_status IN VARCHAR2) AS
    BEGIN
        UPDATE repair_job SET status = p_status WHERE job_id = p_job_id;

        IF SQL%ROWCOUNT = 0 THEN
            RAISE_APPLICATION_ERROR(-20002, 'Job ' || p_job_id || ' not found.');
        END IF;

        COMMIT;
        DBMS_OUTPUT.PUT_LINE('Job ' || p_job_id || ' updated to ' || p_status);
    EXCEPTION
        WHEN OTHERS THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('Error: ' || SQLERRM);
    END update_job_status;

    -- count how many jobs currently have a given status
    FUNCTION count_jobs_by_status (p_status IN VARCHAR2) RETURN NUMBER AS
        v_count NUMBER;
    BEGIN
        SELECT COUNT(*) INTO v_count FROM repair_job WHERE status = p_status;
        RETURN v_count;
    END count_jobs_by_status;

    -- CURSOR: loop through and print all jobs with a given status
    PROCEDURE list_jobs_by_status (p_status IN VARCHAR2) AS
        CURSOR c_jobs IS
            SELECT job_id, item_id, date_due
            FROM repair_job
            WHERE status = p_status;
    BEGIN
        FOR r_job IN c_jobs LOOP
            DBMS_OUTPUT.PUT_LINE('Job ' || r_job.job_id ||
                                  ' | Item ' || r_job.item_id ||
                                  ' | Due ' || TO_CHAR(r_job.date_due, 'YYYY-MM-DD'));
        END LOOP;
    END list_jobs_by_status;

END pkg_repair;
/

